# Per-strategy routing config.
#
# Key = strategy_id sent by TradingView in the alert payload.
# ONE TradingView alert → ONE strategy here → fans out to N enabled exchanges.
#
# `base_asset` is the canonical ticker. Supported: BTC, ETH, SOL, BNB.
# The middleware maps it to each exchange's native symbol automatically:
#   - Hyperliquid:        BTC,    ETH,    SOL,    BNB     (bare ticker)
#   - Bybit linear perp:  BTCUSDT, ETHUSDT, SOLUSDT, BNBUSDT
#
# `venues` maps exchange name → enabled (bool). `false` keeps the row
# configured but skips orders — useful for pausing one venue while keeping
# the other running.
#
# Per-signal position size is NOT configured here. It comes from the
# TradingView alert payload's `quantity_usd` field, supplied by your
# pine-script sizing logic. Tweak your strategy's sizing → reflects
# immediately, no middleware redeploy.

strategies:
  MR_VOTING_BTC_6H:
    base_asset: BTC
    venues:
      hyperliquid: true
      bybit: false

  DON_CHANNEL_ETH_1H:
    base_asset: ETH
    venues:
      hyperliquid: true
      bybit: true

  VWAP_ATR_BTC_4H:
    base_asset: BTC
    venues:
      hyperliquid: true
      bybit: true

  SMA_CROSS_SOL_1H:
    base_asset: SOL
    venues:
      hyperliquid: false
      bybit: false
