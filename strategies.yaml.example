# Per-strategy routing config.
# Key = strategy_id sent by TradingView in the alert payload.
# `symbol` uses each exchange's native naming convention:
#   - Bybit linear perp:  BTCUSDT, ETHUSDT, SOLUSDT, ...
#   - Hyperliquid perp:   BTC, ETH, SOL, ...
# `quantity_usd` is the notional position size for each entry signal.
# `leverage` is applied on the exchange before the order is placed.

strategies:
  MR_VOTING_BTC_6H:
    exchange: bybit
    symbol: BTCUSDT
    quantity_usd: 500
    leverage: 3
    enabled: true

  DON_CHANNEL_ETH_1H:
    exchange: bybit
    symbol: ETHUSDT
    quantity_usd: 300
    leverage: 3
    enabled: true

  VWAP_ATR_BTC_4H:
    exchange: hyperliquid
    symbol: BTC
    quantity_usd: 500
    leverage: 5
    enabled: true

  SMA_CROSS_SOL_1H:
    exchange: hyperliquid
    symbol: SOL
    quantity_usd: 200
    leverage: 5
    enabled: false
