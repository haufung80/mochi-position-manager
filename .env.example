# --- App ---
WEBHOOK_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./data/middleware.db
LOG_LEVEL=INFO
DRY_RUN=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Bybit (V5, USDT perps) ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# --- Hyperliquid ---
# HYPERLIQUID_PRIVATE_KEY: the AGENT wallet's private key (trade-only — cannot withdraw).
#   Generate via HL UI: top-right avatar -> API -> Generate Agent.
# HYPERLIQUID_ACCOUNT_ADDRESS: the LEADER wallet's address (the wallet that created
#   the vault, or your main HL account if not using a vault).
# HYPERLIQUID_VAULT_ADDRESS: OPTIONAL — set to the vault address (from HL UI after
#   you create the vault) to make every trade execute on behalf of the vault.
#   Leave blank to trade the leader's personal HL account directly.
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_VAULT_ADDRESS=
HYPERLIQUID_TESTNET=false

# --- Retry policy ---
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SEC=2
RETRY_MAX_DELAY_SEC=60
