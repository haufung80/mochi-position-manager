# --- App ---
WEBHOOK_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./data/middleware.db
LOG_LEVEL=INFO
DRY_RUN=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Bybit (V5, USDT perps) ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# --- Hyperliquid ---
# HYPERLIQUID_PRIVATE_KEY: the AGENT wallet's private key (trade-only — cannot withdraw).
#   Generate via HL UI: top-right avatar -> API -> Generate Agent.
# HYPERLIQUID_ACCOUNT_ADDRESS: the LEADER wallet's address (the wallet that created
#   the vault, or your main HL account if not using a vault).
# HYPERLIQUID_VAULT_ADDRESS: OPTIONAL — set to the vault address (from HL UI after
#   you create the vault) to make every trade execute on behalf of the vault.
#   Leave blank to trade the leader's personal HL account directly.
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_VAULT_ADDRESS=
HYPERLIQUID_TESTNET=false

# --- Funding-arbitrage execution (optional; directional-only deploys can omit) ---
# FUNDING_ARB_SECRET: X-Arb-Secret API-key header the signal app must send.
#   Leave blank to keep the /funding-arb API disabled — it returns 503 until set.
# The arb book on each venue is a SEPARATE, separately-credentialed account so arb
# fills never net against the directional positions (and HL whole-coin close /
# account-wide funding stay safe). Fill these only when running the arb feature:
#   - Bybit: a sub-account with its OWN API key/secret (set to cross/portfolio margin).
#   - Hyperliquid: a SEPARATE account (own agent key + account address; its own margin).
FUNDING_ARB_SECRET=
BYBIT_ARB_API_KEY=
BYBIT_ARB_API_SECRET=
HYPERLIQUID_ARB_PRIVATE_KEY=
HYPERLIQUID_ARB_ACCOUNT_ADDRESS=

# --- Retry policy ---
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SEC=2
RETRY_MAX_DELAY_SEC=60

# --- Backups: Litestream -> S3-compatible storage (continuous SQLite replication) ---
# Leave blank to disable — the `litestream` sidecar idles until these are set.
# Cloudflare R2 free tier recommended (10GB free): create a bucket + an R2 API token
# (Account > R2 > Manage API Tokens), then:
#   LITESTREAM_S3_REGION=auto
#   LITESTREAM_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# (AWS S3: set the bucket's region, leave endpoint blank. Backblaze B2: set its S3 endpoint.)
LITESTREAM_S3_BUCKET=
LITESTREAM_S3_ENDPOINT=
LITESTREAM_S3_REGION=auto
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
